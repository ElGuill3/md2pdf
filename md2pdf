#!/bin/sh

set -u

PROGRAM=md2pdf
VERSION=0.1.0
# This signature lets uninstall.sh distinguish the public launcher from other files.
INSTALL_SIGNATURE='md2pdf-public-launcher-0.1.0'
stage_dir=
publish_tmp=
caller_umask=$(umask)

print_help() {
  cat <<'EOF'
Usage: md2pdf [OPTIONS] INPUT [OUTPUT]

Convert Markdown to a styled PDF with Pandoc and Typst.

Options:
  -o, --output FILE      Write the PDF to FILE.
      --profile NAME     Override the metadata profile.
  -q, --quiet            Suppress progress and the final success message.
  -h, --help             Show this help and exit.
      --version          Show the version and exit.

Profiles: general, technical, report, academic

The default output is placed beside INPUT. OUTPUT is retained as a legacy
positional form and cannot be combined with --output.

Metadata uses the md2pdf mapping. md2pdf.profile selects a profile; a
top-level profile key is accepted as a compatibility alias.

Exit codes:
  0  Success, help, or version
  2  Invalid command-line usage
  3  Invalid input or output path
  4  Invalid runtime data, metadata, or resource
  5  Missing runtime dependency
  6  Pandoc or Typst conversion failure
  7  Atomic publication failure
EOF
}

usage_error() {
  printf '%s: %s\n' "$PROGRAM" "$1" >&2
  printf "Try '%s --help' for usage.\n" "$PROGRAM" >&2
  exit 2
}

fail() {
  fail_code=$1
  shift
  printf '%s: %s\n' "$PROGRAM" "$*" >&2
  exit "$fail_code"
}

inform() {
  [ "$quiet" = true ] || printf '%s\n' "$*" >&2
}

cleanup() {
  if [ -n "$publish_tmp" ]; then
    rm -f "$publish_tmp"
  fi
  if [ -n "$stage_dir" ]; then
    rm -rf "$stage_dir"
  fi
}

signal_exit() {
  signal_status=$1
  trap - 0 HUP INT TERM
  cleanup
  exit "$signal_status"
}

absolute_path() {
  absolute_input=$1
  absolute_parent=$(dirname "$absolute_input") || return 1
  absolute_name=$(basename "$absolute_input") || return 1
  absolute_parent=$(CDPATH= cd -P "$absolute_parent" 2>/dev/null && pwd -P) || return 1
  printf '%s/%s\n' "$absolute_parent" "$absolute_name"
}

canonical_path() {
  canonical_input=$1
  if command -v realpath >/dev/null 2>&1; then
    canonical_result=$(realpath "$canonical_input" 2>/dev/null) && {
      printf '%s\n' "$canonical_result"
      return 0
    }
  fi
  absolute_path "$canonical_input"
}

file_identity() {
  identity_path=$1
  if identity_value=$(stat -c '%d:%i' "$identity_path" 2>/dev/null); then
    printf '%s\n' "$identity_value"
    return 0
  fi
  if identity_value=$(stat -f '%d:%i' "$identity_path" 2>/dev/null); then
    printf '%s\n' "$identity_value"
    return 0
  fi
  return 1
}

file_mode() {
  mode_path=$1
  if mode_value=$(stat -c '%a' "$mode_path" 2>/dev/null); then
    printf '%s\n' "$mode_value"
    return 0
  fi
  if mode_value=$(stat -f '%Lp' "$mode_path" 2>/dev/null); then
    printf '%s\n' "$mode_value"
    return 0
  fi
  return 1
}

mode_from_umask() {
  case $caller_umask in
    [0-7][0-7][0-7]|[0-7][0-7][0-7][0-7]) ;;
    *) return 1 ;;
  esac
  mode_value=$((0666 & (0777 ^ 0$caller_umask)))
  printf '%03o\n' "$mode_value"
}

valid_profile() {
  case $1 in
    general|technical|report|academic) return 0 ;;
    *) return 1 ;;
  esac
}

show_tool_error() {
  tool_message=$1
  tool_log=$2
  printf '%s: %s\n' "$PROGRAM" "$tool_message" >&2
  while IFS= read -r tool_line || [ -n "$tool_line" ]; do
    printf '  %s\n' "$tool_line" >&2
  done < "$tool_log"
}

input=
legacy_output=
option_output=
cli_profile=
quiet=false

while [ "$#" -gt 0 ]; do
  case $1 in
    -h|--help)
      print_help
      exit 0
      ;;
    --version)
      printf '%s %s\n' "$PROGRAM" "$VERSION"
      exit 0
      ;;
    -o|--output)
      [ "$#" -ge 2 ] || usage_error "option '$1' requires a file"
      [ -z "$option_output" ] || usage_error "output was specified more than once"
      option_output=$2
      shift 2
      ;;
    --output=*)
      [ -z "$option_output" ] || usage_error "output was specified more than once"
      option_output=${1#*=}
      [ -n "$option_output" ] || usage_error "option '--output' requires a file"
      shift
      ;;
    --profile)
      [ "$#" -ge 2 ] || usage_error "option '--profile' requires a name"
      [ -z "$cli_profile" ] || usage_error "profile was specified more than once"
      cli_profile=$2
      shift 2
      ;;
    --profile=*)
      [ -z "$cli_profile" ] || usage_error "profile was specified more than once"
      cli_profile=${1#*=}
      [ -n "$cli_profile" ] || usage_error "option '--profile' requires a name"
      shift
      ;;
    -q|--quiet)
      quiet=true
      shift
      ;;
    --)
      shift
      while [ "$#" -gt 0 ]; do
        if [ -z "$input" ]; then
          input=$1
        elif [ -z "$legacy_output" ]; then
          legacy_output=$1
        else
          usage_error "too many positional arguments"
        fi
        shift
      done
      ;;
    -*) usage_error "unknown option: $1" ;;
    *)
      if [ -z "$input" ]; then
        input=$1
      elif [ -z "$legacy_output" ]; then
        legacy_output=$1
      else
        usage_error "too many positional arguments"
      fi
      shift
      ;;
  esac
done

[ -n "$input" ] || usage_error "an input file is required"
[ -z "$legacy_output" ] || [ -z "$option_output" ] || \
  usage_error "positional OUTPUT cannot be combined with --output"

if [ -n "$cli_profile" ] && ! valid_profile "$cli_profile"; then
  usage_error "invalid profile '$cli_profile'"
fi

if [ -n "$option_output" ]; then
  output=$option_output
elif [ -n "$legacy_output" ]; then
  output=$legacy_output
else
  case $input in
    *.md|*.MD|*.markdown|*.MARKDOWN) output=${input%.*}.pdf ;;
    *) output=$input.pdf ;;
  esac
fi

[ -f "$input" ] || fail 3 "input is not a regular file: $input"
[ -r "$input" ] || fail 3 "input is not readable: $input"

output_parent=$(dirname "$output") || fail 3 "cannot resolve output parent: $output"
[ -d "$output_parent" ] || fail 3 "output parent is not a directory: $output_parent"
[ -w "$output_parent" ] || fail 3 "output parent is not writable: $output_parent"
[ ! -d "$output" ] || fail 3 "output path is a directory: $output"

input_path=$(canonical_path "$input") || fail 3 "cannot resolve input path: $input"
output_path=$(absolute_path "$output") || fail 3 "cannot resolve output path: $output"
output_identity=$(canonical_path "$output") || fail 3 "cannot resolve output path: $output"

if [ "$input_path" = "$output_identity" ]; then
  fail 3 "input and output must be different files"
fi
if [ -e "$output" ] || [ -L "$output" ]; then
  input_identity=$(file_identity "$input_path") || \
    fail 3 "cannot identify input file: $input"
  target_identity=$(file_identity "$output_identity") || \
    fail 3 "cannot identify output file: $output"
  if [ "$input_identity" = "$target_identity" ]; then
    fail 3 "input and output must be different files"
  fi
fi

input_dir=$(dirname "$input_path")
output_dir=$(dirname "$output_path")

script_ref=$0
case $script_ref in
  */*) ;;
  *) script_ref=$(command -v "$script_ref" 2>/dev/null || printf '%s' "$script_ref") ;;
esac
script_dir=$(dirname "$script_ref")
script_dir=$(CDPATH= cd -P "$script_dir" 2>/dev/null && pwd -P) || \
  fail 4 "cannot resolve the executable directory"

required_runtime_files='filters/runtime.lua
filters/citations.lua
typst/template.typ
typst/document.typ
typst/theme.typ
typst/page.typ
typst/profiles/shared.typ
typst/profiles/general.typ
typst/profiles/technical.typ
typst/profiles/report.typ
typst/profiles/academic.typ'

complete_data_dir() {
  complete_candidate=$1
  for complete_file in $required_runtime_files; do
    [ -r "$complete_candidate/$complete_file" ] || return 1
  done
  return 0
}

data_dir=
if [ -n "${MD2PDF_DATA_DIR+x}" ]; then
  [ -n "$MD2PDF_DATA_DIR" ] || fail 4 "MD2PDF_DATA_DIR is empty"
  data_dir=$MD2PDF_DATA_DIR
else
  for data_candidate in \
    "$script_dir/share/md2pdf" \
    "$script_dir/../share/md2pdf" \
    "${XDG_DATA_HOME:-${HOME:-}/.local/share}/md2pdf"
  do
    if complete_data_dir "$data_candidate"; then
      data_dir=$data_candidate
      break
    fi
  done
fi

[ -n "$data_dir" ] || fail 4 "cannot locate the md2pdf data directory"
data_dir=$(canonical_path "$data_dir") || fail 4 "cannot resolve data directory: $data_dir"

for runtime_file in $required_runtime_files; do
  [ -r "$data_dir/$runtime_file" ] || \
    fail 4 "required runtime file is missing: $runtime_file"
done

for dependency in pandoc typst; do
  command -v "$dependency" >/dev/null 2>&1 || \
    fail 5 "required dependency not found: $dependency"
done

umask 077
stage_dir=$(mktemp -d "${TMPDIR:-/tmp}/md2pdf.XXXXXXXX") || \
  fail 4 "cannot create a staging directory"
trap cleanup 0
trap 'signal_exit 129' HUP
trap 'signal_exit 130' INT
trap 'signal_exit 143' TERM

mkdir -p "$stage_dir/runtime/profiles" "$stage_dir/assets" \
  "$stage_dir/citations" || \
  fail 4 "cannot prepare the staging directory"
for runtime_file in template.typ document.typ theme.typ page.typ; do
  cp "$data_dir/typst/$runtime_file" "$stage_dir/runtime/$runtime_file" || \
    fail 4 "cannot stage runtime file: typst/$runtime_file"
done
for profile_file in shared.typ general.typ technical.typ report.typ academic.typ; do
  cp "$data_dir/typst/profiles/$profile_file" \
    "$stage_dir/runtime/profiles/$profile_file" || \
    fail 4 "cannot stage runtime file: typst/profiles/$profile_file"
done

filter_error=$stage_dir/filter-error.txt
pandoc_error=$stage_dir/pandoc-error.txt
inform 'Converting Markdown...'
if ! MD2PDF_STAGE_DIR=$stage_dir \
     MD2PDF_SOURCE_DIR=$input_dir \
     MD2PDF_CLI_PROFILE=$cli_profile \
     MD2PDF_FILTER_ERROR=$filter_error \
     pandoc "$input_path" \
       --from=markdown+yaml_metadata_block-raw_attribute-raw_html-raw_tex \
       --to=typst \
        --standalone \
        --template="$stage_dir/runtime/template.typ" \
        --lua-filter="$data_dir/filters/runtime.lua" \
        --citeproc \
        --lua-filter="$data_dir/filters/citations.lua" \
        --resource-path="$input_dir" \
       --wrap=none \
       --strip-comments \
       > "$stage_dir/document.typ" 2> "$pandoc_error"
then
  if [ -s "$filter_error" ]; then
    IFS= read -r filter_message < "$filter_error"
    fail 4 "$filter_message"
  fi
  if [ -f "$stage_dir/citations-requested" ] && \
     [ ! -f "$stage_dir/citations-processed" ]; then
    show_tool_error "Citation processing failed" "$pandoc_error"
    exit 4
  fi
  show_tool_error "Pandoc conversion failed" "$pandoc_error"
  exit 6
fi
if [ -s "$pandoc_error" ]; then
  while IFS= read -r pandoc_line || [ -n "$pandoc_line" ]; do
    printf '%s\n' "$pandoc_line" >&2
  done < "$pandoc_error"
fi

typst_fonts=$stage_dir/typst-fonts.txt
typst_fonts_error=$stage_dir/typst-fonts-error.txt
inform 'Rendering PDF...'
if typst fonts > "$typst_fonts" 2> "$typst_fonts_error"; then
  while IFS='|' read -r font_role font_family; do
    [ -n "$font_role" ] || continue
    font_found=false
    while IFS= read -r available_font || [ -n "$available_font" ]; do
      if [ "$available_font" = "$font_family" ]; then
        font_found=true
        break
      fi
    done < "$typst_fonts"
    if [ "$font_found" = false ]; then
      printf '%s: warning: preferred %s font is unavailable: %s; using configured fallbacks\n' \
        "$PROGRAM" "$font_role" "$font_family" >&2
    fi
  done < "$stage_dir/preferred-fonts.txt"
else
  printf '%s: warning: unable to verify preferred fonts; rendering may vary\n' \
    "$PROGRAM" >&2
  if [ -s "$typst_fonts_error" ]; then
    while IFS= read -r font_line || [ -n "$font_line" ]; do
      printf '  %s\n' "$font_line" >&2
    done < "$typst_fonts_error"
  fi
fi

typst_error=$stage_dir/typst-error.txt
if ! (CDPATH= cd "$stage_dir" && \
      typst compile --root "$stage_dir" document.typ output.pdf) \
      > "$stage_dir/typst-output.txt" 2> "$typst_error"
then
  show_tool_error "Typst compilation failed" "$typst_error"
  exit 6
fi
if [ -s "$typst_error" ]; then
  while IFS= read -r typst_line || [ -n "$typst_line" ]; do
    printf '%s\n' "$typst_line" >&2
  done < "$typst_error"
fi

inform 'Publishing PDF...'
publish_tmp=$(mktemp "$output_dir/.md2pdf.XXXXXXXX.pdf") || \
  fail 7 "cannot create an atomic publication file in: $output_dir"
if ! cp "$stage_dir/output.pdf" "$publish_tmp"; then
  fail 7 "cannot copy the completed PDF into: $output_dir"
fi
if [ -f "$output_path" ] && [ ! -L "$output_path" ]; then
  final_mode=$(file_mode "$output_path") || \
    fail 7 "cannot read existing PDF permissions: $output_path"
else
  final_mode=$(mode_from_umask) || fail 7 "cannot interpret caller umask: $caller_umask"
fi
chmod "$final_mode" "$publish_tmp" || fail 7 "cannot set final PDF permissions"
if ! mv -f "$publish_tmp" "$output_path"; then
  fail 7 "cannot publish the completed PDF: $output_path"
fi
publish_tmp=

if [ "$quiet" = false ]; then
  printf 'PDF written to %s\n' "$output_path"
fi
